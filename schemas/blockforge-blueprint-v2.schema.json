{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blockforge.dev/schemas/blockforge-blueprint-v2.schema.json",
  "title": "BlockForge Blueprint v2",
  "description": "BlockForge blueprint protocol with Minecraft block state properties.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "minecraftVersion",
    "generator",
    "size",
    "palette",
    "blocks"
  ],
  "properties": {
    "schemaVersion": {
      "const": 2
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9_/-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "minecraftVersion": {
      "const": "1.21.1"
    },
    "generator": {
      "const": "BlockForge"
    },
    "size": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height", "depth"],
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "depth": { "type": "integer", "minimum": 1 }
      }
    },
    "origin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "z"],
      "properties": {
        "x": { "type": "integer" },
        "y": { "type": "integer" },
        "z": { "type": "integer" }
      }
    },
    "palette": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "properties": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      }
    },
    "blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["x", "y", "z", "state"],
        "properties": {
          "x": { "type": "integer" },
          "y": { "type": "integer" },
          "z": { "type": "integer" },
          "state": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
