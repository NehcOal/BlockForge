{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blockforge.local/schemas/blockforge-pack-v1.schema.json",
  "title": "BlockForge Blueprint Pack v1",
  "type": "object",
  "required": [
    "schemaVersion",
    "packId",
    "name",
    "version",
    "minecraftVersion",
    "blockforgeVersion",
    "blueprints"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "packId": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "minecraftVersion": {
      "const": "1.21.1"
    },
    "blockforgeVersion": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "blueprints": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "path"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_-]+$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "allOf": [
              {
                "pattern": "^blueprints/"
              },
              {
                "pattern": "\\.(blueprint\\.)?json$"
              },
              {
                "not": {
                  "pattern": "(^|/)\\.\\.(/|$)"
                }
              },
              {
                "not": {
                  "pattern": "\\\\"
                }
              },
              {
                "not": {
                  "pattern": "^/"
                }
              },
              {
                "not": {
                  "pattern": "^[A-Za-z]:"
                }
              }
            ]
          },
          "description": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "previewImage": {
            "type": "string"
          }
        }
      }
    }
  }
}
